# ------------------------------------------------------------------
# Yanova Solutions — environment configuration
# Copy this file to ".env" (locally) OR paste these as environment
# variables in the Hostinger Node.js app panel (production).
# ------------------------------------------------------------------

# Port the Node server listens on.
# On Hostinger this is provided automatically — leave as-is locally.
PORT=3000

# Node environment: development | production
NODE_ENV=production

# --- Admin account (used to sign in at /admin/login) ---
ADMIN_USERNAME=admin@yanovasolutions.tech
ADMIN_PASSWORD=adminYanova!2026

# Secret used to sign admin session tokens (JWT).
# Generate a new one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# How long an admin login stays valid.
JWT_EXPIRES_IN=7d
